# ── Server ────────────────────────────────────────────────────────────────────
# Public base URL of this API (used to build file URLs returned to the frontend)
BASE_URL=http://localhost:8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins, or * for development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=forensics.db

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=500

NEXT_PUBLIC_API_URL=http://localhost:8000/api
